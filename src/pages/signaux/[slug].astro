---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('signaux');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{post.data.title} — Forme V</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --white: #FAFAF7; --ink: #1A1A18; --gray-mid: #6B6B68; --gray-rule: #D0D0C8; --blue-ink: #1E3A5F; --ff-sans: 'Inter', 'Helvetica Neue', Arial, sans-serif; }
    body { background: var(--white); color: var(--ink); font-family: var(--ff-sans); -webkit-font-smoothing: antialiased; }
    .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--white); border-bottom: 1px solid var(--gray-rule); height: 56px; display: flex; align-items: center; }
    .nav__inner { max-width: 1200px; margin: 0 auto; padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; width: 100%; }
    .nav__logo { font-size: 0.9375rem; font-weight: 500; text-decoration: none; color: var(--ink); }
    .nav__back { font-size: 0.8125rem; text-decoration: none; color: var(--gray-mid); letter-spacing: 0.04em; }
    .nav__back:hover { color: var(--ink); }
    .article { max-width: 680px; margin: 0 auto; padding: calc(10rem + 56px) 2rem 8rem; }
    .article__eyebrow { font-size: 0.6875rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-mid); margin-bottom: 2rem; }
    .article__title { font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 300; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 1.5rem; }
    .article__rule { width: 48px; height: 1px; background: var(--ink); margin-bottom: 2rem; }
    .article__desc { font-size: 1.1875rem; line-height: 1.65; color: #2C2C2A; margin-bottom: 4rem; }
    hr { border: none; border-top: 1px solid var(--gray-rule); margin-bottom: 4rem; }
    .article__body { font-size: 1rem; line-height: 1.8; color: var(--ink); }
    .article__body p { margin-bottom: 1.5rem; }
    .article__body h2 { font-size: 1.5rem; font-weight: 400; letter-spacing: -0.02em; margin: 3rem 0 1rem; }
    .article__body h3 { font-size: 1.25rem; font-weight: 400; margin: 2rem 0 0.75rem; }
    footer { border-top: 1px solid var(--gray-rule); padding: 3rem 0; margin-top: 8rem; }
    .footer__inner { max-width: 1200px; margin: 0 auto; padding: 0 2rem; display: flex; justify-content: space-between; align-items: flex-end; }
    .footer__brand { font-size: 0.9375rem; font-weight: 500; }
    .footer__tagline { font-size: 0.8125rem; color: var(--gray-mid); margin-top: 0.25rem; }
  </style>
</head>
<body>
  <nav class="nav">
    <div class="nav__inner">
      <a href="/" class="nav__logo">Forme V</a>
      <a href="/signaux" class="nav__back">← Signaux</a>
    </div>
  </nav>
  <article class="article">
    <p class="article__eyebrow">{new Date(post.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
    <h1 class="article__title">{post.data.title}</h1>
    <div class="article__rule"></div>
    <p class="article__desc">{post.data.description}</p>
    <hr />
    <div class="article__body">
      <Content />
    </div>
  </article>
  <footer>
    <div class="footer__inner">
      <div>
        <p class="footer__brand">Forme V</p>
        <p class="footer__tagline">Architecture de récits et dispositifs d'attention</p>
      </div>
    </div>
  </footer>
</body>
</html>