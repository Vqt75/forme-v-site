---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
const posts = await getCollection('signaux');
return posts.map(post => ({
params: { slug: post.id },
props: { post }
}));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{post.data.title}</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box}

body{
font-family:'Inter',sans-serif;
background:#FAFAF7;
color:#1A1A18;
}

/* NAV */
.nav{
position:fixed;
top:0;
width:100%;
height:56px;
background:white;
border-bottom:1px solid #ddd;
display:flex;
align-items:center;
z-index:10;
}

.nav__inner{
max-width:1100px;
margin:auto;
padding:0 2rem;
display:flex;
justify-content:space-between;
width:100%;
}

.nav a{
text-decoration:none;
color:#666;
font-size:0.85rem;
margin-left:1.5rem;
}

/* BACK BUTTON */
.back{
position:fixed;
top:70px;
left:2rem;
font-size:0.85rem;
color:#666;
text-decoration:none;
z-index:9;
}

.back:hover{color:black}

/* ARTICLE */
.article{
max-width:700px;
margin:auto;
padding:calc(8rem + 56px) 2rem 6rem;
}

.title{
font-size:clamp(2rem,4vw,3rem);
font-weight:300;
margin-bottom:1.5rem;
}

.desc{
font-size:1.1rem;
color:#444;
margin-bottom:3rem;
}

.content p{
margin-bottom:1.5rem;
line-height:1.7;
}

/* FOOTER */
footer{
border-top:1px solid #ddd;
padding:2rem;
max-width:1100px;
margin:auto;
}
</style>
</head>

<body>

<nav class="nav">
<div class="nav__inner">
<a href="/">Forme V</a>
<div>
<a href="/#methode">Méthode</a>
<a href="/#situations">Situations</a>
<a href="/signaux">Signaux</a>
<a href="/#apropos">À propos</a>
</div>
</div>
</nav>

<a href="/signaux" class="back">← Tous les signaux</a>

<article class="article">
<h1 class="title">{post.data.title}</h1>
<p class="desc">{post.data.description}</p>

<div class="content">
<Content />
</div>
</article>

<footer>
<p>Forme V — Architecture de récits et dispositifs d’attention</p>
</footer>

</body>
</html>