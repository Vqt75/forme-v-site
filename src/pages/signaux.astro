---
import { getCollection } from 'astro:content';

const posts = await getCollection('signaux');

const sorted = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const featured = sorted[0];
const archive = sorted.slice(1);

function formatDate(date: string) {
  return new Date(date).toLocaleDateString('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Signaux — Forme V</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap"
    rel="stylesheet"
  />

  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --white: #FAFAF7;
      --ink: #1A1A18;
      --gray-mid: #6B6B68;
      --gray-rule: #D0D0C8;
      --blue-ink: #1E3A5F;
      --ff-sans: 'Inter', 'Helvetica Neue', Arial, sans-serif;
      --max-w: 1200px;
      --reading-w: 720px;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--white);
      color: var(--ink);
      font-family: var(--ff-sans);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      line-height: 1.6;
    }

    a {
      color: inherit;
    }

    /* NAV */

    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: var(--white);
      border-bottom: 1px solid var(--gray-rule);
      height: 56px;
      display: flex;
      align-items: center;
    }

    .nav__inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      gap: 1rem;
    }

    .nav__logo {
      font-size: 0.9375rem;
      font-weight: 500;
      text-decoration: none;
      color: var(--ink);
      white-space: nowrap;
    }

    .nav__links {
      display: flex;
      gap: 2rem;
      list-style: none;
      flex-wrap: wrap;
    }

    .nav__links a,
    .footer__links a {
      font-size: 0.8125rem;
      letter-spacing: 0.04em;
      text-decoration: none;
      color: var(--gray-mid);
      transition: color 0.2s;
    }

    .nav__links a:hover,
    .footer__links a:hover {
      color: var(--ink);
    }

    .nav__cta {
      font-size: 0.8125rem;
      letter-spacing: 0.04em;
      text-decoration: none;
      color: var(--ink);
      border: 1px solid var(--ink);
      padding: 0.375rem 1rem;
      white-space: nowrap;
    }

    /* GLOBAL */

    .container {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 2rem;
    }

    .container--reading {
      max-width: calc(var(--reading-w) + 4rem);
      margin: 0 auto;
      padding: 0 2rem;
    }

    .t-label {
      font-size: 0.6875rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gray-mid);
    }

    .rule {
      border: none;
      border-top: 1px solid var(--gray-rule);
    }

    /* HERO */

    .hero {
      padding: calc(11rem + 56px) 0 5rem;
    }

    .hero__grid {
      display: grid;
      grid-template-columns: 1fr 1.15fr;
      gap: 4rem;
      align-items: start;
    }

    .hero__title {
      font-size: clamp(3rem, 6vw, 5.5rem);
      font-weight: 300;
      letter-spacing: -0.04em;
      line-height: 0.98;
      margin-bottom: 2.25rem;
    }

    .hero__rule {
      width: 48px;
      height: 1px;
      background: var(--ink);
      margin-bottom: 2rem;
    }

    .hero__intro {
      font-size: 1.125rem;
      line-height: 1.75;
      color: #2C2C2A;
      max-width: 620px;
    }

    .hero__micro {
      margin-top: 2rem;
      font-size: 0.8125rem;
      letter-spacing: 0.04em;
      color: var(--gray-mid);
    }

    /* INTENTION */

    .intention {
      padding: 4rem 0 5rem;
    }

    .intention__grid {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 3rem;
      align-items: start;
    }

    .intention__body {
      max-width: 760px;
    }

    .intention__body p {
      font-size: 1rem;
      line-height: 1.85;
      color: var(--ink);
      margin-bottom: 1.35rem;
    }

    .intention__body p:last-child {
      margin-bottom: 0;
    }

    /* FEATURED */

    .featured {
      padding: 0 0 5rem;
    }

    .featured__header {
      margin-bottom: 1.5rem;
    }

    .featured__card {
      border-top: 1px solid var(--gray-rule);
      border-bottom: 1px solid var(--gray-rule);
      padding: 2.75rem 0;
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 4rem;
      align-items: start;
    }

    .featured__meta {
      font-size: 0.8125rem;
      letter-spacing: 0.04em;
      color: var(--gray-mid);
    }

    .featured__title {
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      font-weight: 300;
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin-bottom: 1rem;
      max-width: 760px;
    }

    .featured__title a {
      text-decoration: none;
      color: var(--ink);
    }

    .featured__title a:hover {
      color: var(--blue-ink);
    }

    .featured__desc {
      font-size: 1rem;
      line-height: 1.8;
      color: var(--gray-mid);
      max-width: 760px;
      margin-bottom: 1.25rem;
    }

    .featured__link {
      display: inline-block;
      text-decoration: none;
      font-size: 0.8125rem;
      letter-spacing: 0.06em;
      color: var(--ink);
      transition: opacity 0.2s;
    }

    .featured__link:hover {
      opacity: 0.6;
    }

    /* ARCHIVE */

    .archive {
      padding: 0 0 5rem;
    }

    .archive__header {
      margin-bottom: 1.5rem;
    }

    .archive__list {
      border-top: 1px solid var(--gray-rule);
    }

    .archive__item {
      padding: 2.2rem 0;
      border-bottom: 1px solid var(--gray-rule);
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 4rem;
      align-items: start;
    }

    .archive__date {
      font-size: 0.8125rem;
      letter-spacing: 0.04em;
      color: var(--gray-mid);
    }

    .archive__title {
      font-size: 1.25rem;
      font-weight: 400;
      letter-spacing: -0.02em;
      margin-bottom: 0.65rem;
      line-height: 1.35;
    }

    .archive__title a {
      text-decoration: none;
      color: var(--ink);
    }

    .archive__title a:hover {
      color: var(--blue-ink);
    }

    .archive__desc {
      font-size: 0.9375rem;
      color: var(--gray-mid);
      line-height: 1.7;
      max-width: 760px;
    }

    /* FOOTER */

    footer {
      border-top: 1px solid var(--gray-rule);
      padding: 3rem 0;
    }

    .footer__inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 2rem;
    }

    .footer__brand {
      font-size: 0.9375rem;
      font-weight: 500;
    }

    .footer__tagline {
      font-size: 0.8125rem;
      color: var(--gray-mid);
      margin-top: 0.25rem;
    }

    .footer__copy {
      font-size: 0.6875rem;
      color: var(--gray-mid);
      margin-top: 0.5rem;
      letter-spacing: 0.04em;
    }

    .footer__links {
      display: flex;
      gap: 2rem;
      list-style: none;
      flex-wrap: wrap;
    }

    /* RESPONSIVE */

    @media (max-width: 900px) {
      .nav__links {
        display: none;
      }

      .nav__cta {
        font-size: 0.75rem;
        padding: 0.45rem 0.85rem;
      }

      .container,
      .container--reading,
      .footer__inner {
        padding: 0 1.25rem;
      }

      .hero {
        padding: calc(8rem + 56px) 0 3.5rem;
      }

      .hero__grid,
      .intention__grid,
      .featured__card,
      .archive__item {
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }

      .hero__title {
        margin-bottom: 1.75rem;
      }

      .hero__intro {
        font-size: 1.0625rem;
      }

      .intention {
        padding: 3rem 0 4rem;
      }

      .featured,
      .archive {
        padding: 0 0 4rem;
      }

      .featured__card,
      .archive__item {
        padding: 2rem 0;
      }

      .featured__title {
        font-size: clamp(1.6rem, 8vw, 2.1rem);
      }

      .archive__title {
        font-size: 1.125rem;
      }

      .footer__inner {
        flex-direction: column;
        gap: 1.5rem;
        align-items: flex-start;
      }

      .footer__links {
        gap: 1rem 1.25rem;
      }
    }
  </style>
</head>

<body>

  <nav class="nav">
    <div class="nav__inner">
      <a href="/" class="nav__logo">Forme V</a>

      <ul class="nav__links">
        <li><a href="/#methode">Méthode</a></li>
        <li><a href="/#situations">Situations</a></li>
        <li><a href="/signaux">Signaux</a></li>
        <li><a href="/#apropos">À propos</a></li>
      </ul>

      <a href="/#contact" class="nav__cta">Nous contacter</a>
    </div>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="hero__grid">
        <div>
          <p class="t-label">Signaux</p>
        </div>

        <div>
          <h1 class="hero__title">
            Observations, analyses<br />
            et textes courts<br />
            sur ce qui rend une parole<br />
            visible, lisible ou inaudible.
          </h1>

          <div class="hero__rule"></div>

          <p class="hero__intro">
            Signaux est la rubrique éditoriale de Forme V.
          </p>

          <p class="hero__intro" style="margin-top: 1.25rem;">
            Elle rassemble des textes brefs sur les récits publics, les dispositifs d’attention,
            les formes de circulation de la parole et les situations où quelque chose devient perceptible... ou cesse de l’être.
          </p>

          <p class="hero__intro" style="margin-top: 1.25rem;">
            Il ne s’agit pas de commenter le bruit ambiant, mais d’en décrypter les dynamiques et d'en proposer une lecture.
          </p>

        </div>
      </div>
    </div>
  </section>

  {featured && (
    <section class="featured">
      <div class="container">
        <div class="featured__header">
          <p class="t-label">Signal récent</p>
        </div>

        <div class="featured__card">
          <div class="featured__meta">
            {formatDate(featured.data.date)}
          </div>

          <div>
            <h2 class="featured__title">
              <a href={`/signaux/${featured.id}`}>{featured.data.title}</a>
            </h2>

            <p class="featured__desc">
              {featured.data.description}
            </p>

            <a class="featured__link" href={`/signaux/${featured.id}`}>
              Lire le signal →
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="archive">
    <div class="container">
      <div class="archive__header">
        <p class="t-label">Tous les signaux</p>
      </div>

      <div class="archive__list">
        {archive.length > 0 ? (
          archive.map((post) => (
            <div class="archive__item">
              <div class="archive__date">
                {formatDate(post.data.date)}
              </div>

              <div>
                <h2 class="archive__title">
                  <a href={`/signaux/${post.id}`}>{post.data.title}</a>
                </h2>

                <p class="archive__desc">
                  {post.data.description}
                </p>
              </div>
            </div>
          ))
        ) : (
          <div class="archive__item">
            <div></div>
            <div>
              <p class="archive__desc">
                Aucun autre signal publié pour le moment.
              </p>
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <footer>
    <div class="footer__inner">
      <div>
        <p class="footer__brand">Forme V</p>
        <p class="footer__tagline">Architecture de récits et dispositifs d'attention</p>
        <p class="footer__copy">© 2026</p>
      </div>

      <ul class="footer__links">
        <li><a href="/#methode">Méthode</a></li>
        <li><a href="/#situations">Situations</a></li>
        <li><a href="/signaux">Signaux</a></li>
        <li><a href="/#apropos">À propos</a></li>
        <li><a href="/#contact">Contact</a></li>
        <li><a href="#">Mentions légales</a></li>
      </ul>
    </div>
  </footer>

</body>
</html>