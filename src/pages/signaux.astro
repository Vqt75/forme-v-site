---
import { getCollection } from 'astro:content';

const posts = await getCollection('signaux');
const sorted = posts.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
---

<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Signaux — Forme V</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
--white:#FAFAF7;
--ink:#1A1A18;
--gray:#6B6B68;
--rule:#D0D0C8;
--ff:'Inter', sans-serif;
}

body {
font-family: var(--ff);
background: var(--white);
color: var(--ink);
}

/* NAV */
.nav {
position: fixed;
top:0; left:0; right:0;
height:56px;
background:white;
border-bottom:1px solid var(--rule);
display:flex;
align-items:center;
z-index:10;
}

.nav__inner {
max-width:1200px;
margin:auto;
padding:0 2rem;
display:flex;
justify-content:space-between;
width:100%;
}

.nav a {
text-decoration:none;
color:var(--gray);
font-size:0.85rem;
margin-left:1.5rem;
}

.nav a:hover { color:var(--ink); }

/* HERO */
.hero {
padding:calc(10rem + 56px) 2rem 6rem;
max-width:1200px;
margin:auto;
}

.t-label {
font-size:0.7rem;
letter-spacing:0.12em;
text-transform:uppercase;
color:var(--gray);
margin-bottom:2rem;
}

/* animation */
.hero-title {
font-size:clamp(2.8rem,6vw,5rem);
font-weight:300;
line-height:1.05;
letter-spacing:-0.03em;
margin-bottom:3rem;
}

.line {
opacity:0;
transform:translateY(10px);
transition:all .6s ease;
}

.visible .line { opacity:1; transform:none; }

.line:nth-child(1){ transition-delay:.1s }
.line:nth-child(2){ transition-delay:.3s }

.hero__intro {
max-width:520px;
font-size:1.1rem;
line-height:1.6;
color:#333;
}

/* LIST */
.list {
max-width:1200px;
margin:auto;
padding:2rem;
}

.item {
border-top:1px solid var(--rule);
padding:2rem 0;
display:grid;
grid-template-columns:140px 1fr;
gap:3rem;
}

.item:last-child {
border-bottom:1px solid var(--rule);
}

.date {
font-size:0.8rem;
color:var(--gray);
}

.title a {
text-decoration:none;
color:var(--ink);
font-size:1.2rem;
}

.title a:hover { color:#1E3A5F; }

.desc {
font-size:0.95rem;
color:var(--gray);
margin-top:0.5rem;
}

/* FOOTER */
footer {
margin-top:5rem;
border-top:1px solid var(--rule);
padding:2rem;
max-width:1200px;
margin-left:auto;
margin-right:auto;
}

@media(max-width:700px){
.item { grid-template-columns:1fr; gap:1rem; }
}
</style>
</head>

<body>

<nav class="nav">
<div class="nav__inner">
<a href="/">Forme V</a>
<div>
<a href="/#methode">Méthode</a>
<a href="/#situations">Situations</a>
<a href="/signaux">Signaux</a>
<a href="/#apropos">À propos</a>
</div>
</div>
</nav>

<section class="hero">
<p class="t-label">Signaux</p>

<h1 class="hero-title" id="heroTitle">
<span class="line">Observations, analyses</span><br>
<span class="line">et textes courts.</span>
</h1>

<p class="hero__intro">
Des lectures situées des récits contemporains. Ni tribunes, ni billets d’humeur :
des tentatives pour comprendre ce qui se joue dans les prises de parole publiques.
</p>
</section>

<section class="list">
{sorted.map(post => (
<div class="item">
<p class="date">
{new Date(post.data.date).toLocaleDateString('fr-FR')}
</p>

<div>
<h2 class="title">
<a href={`/signaux/${post.id}`}>{post.data.title}</a>
</h2>
<p class="desc">{post.data.description}</p>
</div>
</div>
))}
</section>

<footer>
<p>Forme V — Architecture de récits et dispositifs d’attention</p>
</footer>

<script>
const title = document.getElementById('heroTitle');
setTimeout(()=> title.classList.add('visible'),100);
</script>

</body>
</html>