---
import { getCollection } from 'astro:content';

const posts = await getCollection('signaux');

const sorted = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function formatDate(date) {
  return new Date(date).toLocaleDateString('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Signaux — Forme V</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap"
    rel="stylesheet"
  />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #0A0A08;
      --white: #FAFAF7;
      --ink: #1A1A18;
      --gray-mid: #6B6B68;
      --gray-light: #E8E8E2;
      --gray-rule: #D0D0C8;
      --blue-ink: #1E3A5F;
      --anthracite: #2C2C2A;
      --ocre: #8B6914;
      --ocre-light: #F5EDD6;
      --ff-sans: 'Inter', 'Helvetica Neue', Arial, sans-serif;
      --space-xs: 0.5rem;
      --space-sm: 1rem;
      --space-md: 2rem;
      --space-lg: 4rem;
      --space-xl: 8rem;
      --space-2xl: 12rem;
      --max-w: 1200px;
      --col-narrow: 600px;
      --grid-gap: 3rem;
    }

    html { font-size: 16px; scroll-behavior: smooth; }

    body {
      background: var(--white);
      color: var(--ink);
      font-family: var(--ff-sans);
      font-weight: 400;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    h1, h2, h3, h4, h5 {
      font-weight: 400;
      letter-spacing: -0.02em;
      line-height: 1.1;
    }

    .t-display {
      font-size: clamp(3rem, 6vw, 5.5rem);
      font-weight: 300;
      letter-spacing: -0.04em;
      line-height: 1;
    }

    .t-headline {
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      font-weight: 300;
      letter-spacing: -0.03em;
    }

    .t-title {
      font-size: clamp(1.2rem, 2vw, 1.5rem);
      font-weight: 400;
      letter-spacing: -0.02em;
    }

    .t-label {
      font-size: 0.6875rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-weight: 400;
      color: var(--gray-mid);
    }

    .container {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 var(--space-md);
    }

    .rule {
      border: none;
      border-top: 1px solid var(--gray-rule);
    }

    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: var(--white);
      border-bottom: 1px solid var(--gray-rule);
      min-height: 56px;
      display: flex;
      align-items: center;
    }

    .nav__inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 var(--space-md);
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      gap: 1rem;
      min-height: 56px;
      position: relative;
    }

    .nav__logo {
      font-size: 0.9375rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      text-decoration: none;
      color: var(--ink);
      white-space: nowrap;
    }

    .nav__links {
      display: flex;
      gap: 2rem;
      list-style: none;
      flex-wrap: wrap;
    }

    .nav__links a,
    .footer__links a {
      font-size: 0.8125rem;
      letter-spacing: 0.04em;
      text-decoration: none;
      color: var(--gray-mid);
      transition: color 0.2s;
    }

    .nav__links a:hover,
    .footer__links a:hover {
      color: var(--ink);
    }

    .nav__cta {
      font-size: 0.8125rem;
      letter-spacing: 0.04em;
      text-decoration: none;
      color: var(--ink);
      border: 1px solid var(--ink);
      padding: 0.375rem 1rem;
      white-space: nowrap;
    }

    section {
      padding: var(--space-xl) 0;
    }

    .section--hero {
      padding: calc(var(--space-2xl) + 56px) 0 var(--space-xl);
    }

    .hero__eyebrow {
      font-size: 0.6875rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--gray-mid);
      margin-bottom: var(--space-md);
    }

    .hero__title {
      margin-bottom: var(--space-lg);
      max-width: 980px;
    }

    .hero__rule {
      width: 48px;
      height: 1px;
      background: var(--ink);
      margin-bottom: var(--space-md);
    }

    .hero__intro {
      font-size: 1.1875rem;
      line-height: 1.65;
      max-width: 700px;
      color: var(--anthracite);
    }

    .hero-title-animated {
      display: flex;
      flex-direction: column;
      gap: 0.06em;
    }

    .hero-line {
      display: block;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.65s ease, transform 0.65s ease;
      will-change: opacity, transform;
    }

    .hero-title-animated.is-visible .hero-line {
      opacity: 1;
      transform: translateY(0);
    }

    .hero-title-animated.is-visible .hero-line:nth-child(1) { transition-delay: 0.05s; }
    .hero-title-animated.is-visible .hero-line:nth-child(2) { transition-delay: 0.22s; }
    .hero-title-animated.is-visible .hero-line:nth-child(3) { transition-delay: 0.34s; }

    .signals {
      padding-top: 0;
    }

    .signals__list {
      border-top: 1px solid var(--gray-rule);
    }

    .signal-item {
      padding: 2.25rem 0;
      border-bottom: 1px solid var(--gray-rule);
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 3rem;
      align-items: start;
    }

    .signal-date {
      font-size: 0.8125rem;
      color: var(--gray-mid);
      letter-spacing: 0.04em;
    }

    .signal-title {
      font-size: 1.25rem;
      font-weight: 400;
      letter-spacing: -0.02em;
      margin-bottom: 0.6rem;
      line-height: 1.35;
    }

    .signal-title a {
      text-decoration: none;
      color: var(--ink);
    }

    .signal-title a:hover {
      color: var(--blue-ink);
    }

    .signal-desc {
      font-size: 0.9375rem;
      color: var(--gray-mid);
      line-height: 1.7;
      max-width: 760px;
    }

    footer {
      border-top: 1px solid var(--gray-rule);
      padding: 3rem 0;
    }

    .footer__inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 var(--space-md);
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 2rem;
    }

    .footer__brand {
      font-size: 0.9375rem;
      font-weight: 500;
    }

    .footer__tagline {
      font-size: 0.8125rem;
      color: var(--gray-mid);
      margin-top: 0.25rem;
    }

    .footer__copy {
      font-size: 0.6875rem;
      color: var(--gray-mid);
      margin-top: 0.5rem;
      letter-spacing: 0.04em;
    }

    .footer__links {
      display: flex;
      gap: 2rem;
      list-style: none;
      flex-wrap: wrap;
    }

    @media (max-width: 900px) {
      html { font-size: 15px; }

      section { padding: 4rem 0; }

      .section--hero { padding: calc(7rem + 56px) 0 4rem; }

      .container,
      .footer__inner { padding: 0 1.25rem; }

      .hero__title { margin-bottom: 2.5rem; }

      .hero__intro {
        font-size: 1.0625rem;
        max-width: 100%;
      }

      .t-display {
        font-size: clamp(2.4rem, 11vw, 4rem);
        line-height: 1.02;
      }

      .nav__links {
        gap: 1rem 1.25rem;
      }

      .nav__cta {
        font-size: 0.75rem;
        padding: 0.45rem 0.85rem;
      }

      .signal-item {
        grid-template-columns: 1fr;
        gap: 0.9rem;
      }

      .footer__inner {
        flex-direction: column;
        gap: 1.5rem;
        align-items: flex-start;
      }

      .footer__links {
        gap: 1rem 1.25rem;
      }
    }

    @media (max-width: 640px) {
      .nav__links {
        display: none;
      }
    }
  </style>
</head>

<body>
  <nav class="nav">
    <div class="nav__inner">
      <a href="/" class="nav__logo">Forme V</a>

      <ul class="nav__links">
        <li><a href="/#methode">Méthode</a></li>
        <li><a href="/#situations">Situations</a></li>
        <li><a href="/signaux">Signaux</a></li>
        <li><a href="/#apropos">À propos</a></li>
      </ul>

      <a href="/#contact" class="nav__cta">Nous contacter</a>
    </div>
  </nav>

  <section class="section--hero">
    <div class="container">
      <p class="hero__eyebrow">Signaux</p>

      <h1 class="t-display hero__title hero-title-animated" id="signauxTitle">
        <span class="hero-line">Observations, analyses</span>
        <span class="hero-line">et textes courts</span>
        <span class="hero-line">sur ce qui rend une parole visible, lisible ou inaudible.</span>
      </h1>

      <div class="hero__rule"></div>

      <p class="hero__intro">
        Des textes courts sur les récits publics, les dispositifs d’attention et les conditions de la parole dans l’espace contemporain.
      </p>
    </div>
  </section>

  <section class="signals">
    <div class="container">
      <div class="signals__list">
        {sorted.map((post) => (
          <div class="signal-item">
            <p class="signal-date">{formatDate(post.data.date)}</p>

            <div>
              <h2 class="signal-title">
                <a href={`/signaux/${post.id}`}>{post.data.title}</a>
              </h2>

              <p class="signal-desc">{post.data.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <footer>
    <div class="footer__inner">
      <div>
        <p class="footer__brand">Forme V</p>
        <p class="footer__tagline">Architecture de récits et dispositifs d'attention</p>
        <p class="footer__copy">© 2026</p>
      </div>

      <ul class="footer__links">
        <li><a href="/#methode">Méthode</a></li>
        <li><a href="/#situations">Situations</a></li>
        <li><a href="/signaux">Signaux</a></li>
        <li><a href="/#apropos">À propos</a></li>
        <li><a href="/#contact">Contact</a></li>
        <li><a href="#">Mentions légales</a></li>
      </ul>
    </div>
  </footer>

  <script>
    function triggerHeroAnimation() {
      const title = document.getElementById('signauxTitle');
      if (!title) return;

      title.classList.remove('is-visible');

      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          title.classList.add('is-visible');
        });
      });
    }

    window.addEventListener('load', function() {
  requestAnimationFrame(function() {
    requestAnimationFrame(function() {
      triggerHeroAnimation();
    });
  });
});
  </script>
</body>
</html>